{
  "name": "dinah",
  "version": "0.0.0-semantically-released",
  "description": "A dynamodb client designed for typescript",
  "homepage": "https://github.com/jayalfredprufrock/dinah#readme",
  "bugs": {
    "url": "https://github.com/jayalfredprufrock/dinah/issues"
  },
  "license": "MIT",
  "author": "Andrew Smiley <jayalfredprufrock@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jayalfredprufrock/dinah.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": "./src/index.ts",
    "./streams": "./src/streams.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./streams": {
        "import": "./dist/streams.mjs",
        "require": "./dist/streams.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "dev": "vp pack --watch",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.1024.0",
    "@aws-sdk/lib-dynamodb": "^3.1024.0",
    "@semantic-release/exec": "^7.1.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "semantic-release": "^25.0.3",
    "typebox": "^1.1.14",
    "vite-plus": "^0.1.14"
  },
  "peerDependencies": {
    "@aws-sdk/client-dynamodb": "^3.1024.0",
    "@aws-sdk/client-dynamodb-streams": "^3.1024.0",
    "@aws-sdk/lib-dynamodb": "^3.1024.0",
    "sift": "^17.1.3",
    "typebox": "^1.1.14"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-dynamodb-streams": {
      "optional": true
    },
    "sift": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "pnpm version ${nextRelease.version} --no-git-tag-version",
          "publishCmd": "pnpm publish --no-git-checks"
        }
      ],
      "@semantic-release/github"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
